{
  "name": "usted-findit",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web --clear --max-workers 1",
    "export:web:api": "expo export --platform web --clear --api-only --max-workers 1",
    "build:preview:android": "eas build --platform android --profile preview",
    "update:preview": "eas update --channel preview",
    "db:auth-generate": "pnpm dlx auth@latest generate --config ./src/lib/auth.ts --output ./src/db/schema/auth.generated.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:clear": "tsx src/db/clear.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:check": "tsx src/scripts/db-check.ts",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.16",
